# ============================================================
# SmartLearn AI - 环境配置模板
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# ⚠️ 生产环境部署前必须完成以下检查:
#   1. 修改所有带 "change-me" 的密码为强随机值
#   2. 设置 ENVIRONMENT=production, DEBUG=false
#   3. 至少配置一个 AI 供应商 API Key
#   4. 将 CORS_ORIGINS 改为实际域名
#   5. 防火墙仅开放 80/443, 不暴露数据库端口
# ============================================================

# ---------- 环境 ----------
# 可选值: development | staging | production
# 生产环境务必设为 production
ENVIRONMENT=development

# ---------- 调试 (生产环境务必设为 false) ----------
DEBUG=false

# ---------- 服务端口 ----------
# Nginx 对外暴露的 HTTP/HTTPS 端口
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---------- 数据库 (PostgreSQL) ----------
# 数据库用户名
POSTGRES_USER=smartlearn_user
# 数据库密码 (长度 ≥ 12, 不要使用默认值)
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
# 数据库名称
POSTGRES_DB=smartlearn

# ---------- 缓存 (Redis) ----------
# Redis 密码 (长度 ≥ 12, 不要使用默认值)
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# ---------- 向量数据库 (Milvus) ----------
# Milvus 使用的 MinIO 凭证
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-to-a-strong-minio-secret-key

# ---------- 认证 ----------
# JWT 签名密钥 (长度 ≥ 32, 使用随机生成的安全字符串)
# 生成方式: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-jwt-secret-at-least-32-chars
# JWT 签名算法
JWT_ALGORITHM=HS256
# Access Token 过期时间 (分钟)
JWT_ACCESS_EXPIRE_MINUTES=30
# Refresh Token 过期时间 (天)
JWT_REFRESH_EXPIRE_DAYS=7

# ---------- AI 服务 (OpenAI 兼容) ----------
# OpenAI API 密钥 (可选, 不设置则 AI 功能不可用)
OPENAI_API_KEY=
# OpenAI API 地址 (可替换为兼容的服务商)
OPENAI_API_BASE=https://api.openai.com/v1
# LLM 模型名称
LLM_MODEL_NAME=gpt-4o-mini
# 嵌入模型名称
EMBEDDING_MODEL_NAME=text-embedding-3-small

# ---------- 多 AI 供应商 (Multi-Provider) ----------
# 以下供应商按需配置，至少配置一个即可启用 AI 功能

# --- GLM (智谱 AI) - 默认聊天主供应商 ---
# 注册地址: https://open.bigmodel.cn/
# 模型名称对照:
#   glm-4-flash     = GLM-4 Flash (免费, 128K上下文, 推荐默认)
#   glm-4           = GLM-4 (标准, 128K上下文)
#   glm-4-plus      = GLM-4 Plus (高精度, 128K上下文)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4-flash

# --- DeepSeek - 高难度问题供应商 ---
# 注册地址: https://platform.deepseek.com/
# 模型名称对照:
#   deepseek-chat   = DeepSeek-V3 (通用对话, 64K上下文)
#   deepseek-reasoner = DeepSeek-R1 (推理增强, 64K上下文)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- SiliconFlow (硅基流动) - 嵌入/TTS/STT ---
# 注册地址: https://siliconflow.cn/
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_TTS_MODEL=CosyVoice
SILICONFLOW_STT_MODEL=SenseVoice

# --- CogView (智谱 AI) - 图像生成 ---
# 注册地址: https://open.bigmodel.cn/
COGVIEW_API_KEY=
COGVIEW_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
COGVIEW_MODEL=cogview-3-flash

# ---------- 向量存储 ----------
# 可选值: inmemory | milvus
VECTOR_STORE_TYPE=inmemory

# ---------- CORS ----------
# 允许的前端源地址 (逗号分隔)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ---------- 对象存储 (OSS) ----------
# 用于头像/文件存储
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_BUCKET=smartlearn

# ---------- 支付 ----------
# 微信支付
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_API_KEY=your-wechat-api-key
# 支付宝
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# ---------- 短信 ----------
SMS_ACCESS_KEY=your-sms-access-key
SMS_SECRET_KEY=your-sms-secret-key
SMS_SIGN_NAME=SmartLearn

# ---------- 邮件 ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@smartlearn.com
SMTP_PASS=your-smtp-password