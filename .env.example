# ============================================================
# SmartLearn AI - 环境配置模板
# 复制此文件为 .env 并填入实际值:  cp .env.example .env
#
# 📌 最低启动只需填 3 项（标 ⭐ 必填）：
#     1. DATABASE_URL   ⭐ 数据库连接串
#     2. REDIS_URL      ⭐ Redis 连接串
#     3. JWT_SECRET     ⭐ JWT 签名密钥
#   再加至少 1 个 AI API Key，应用即可完整运行。
#   支付/短信/邮件/OSS 全部可选，留空不影响启动与管理后台。
# ============================================================


# ────────────────────────────────────────────────────────────
# ⭐ 必填：数据库 (PostgreSQL)
# ────────────────────────────────────────────────────────────
# 标准 PG 连接串，格式: postgresql://用户名:密码@主机:端口/数据库名
# 示例: postgresql://smartlearn:pass@127.0.0.1:5432/smartlearn
# 说明: 填此项后无需再填 DB_HOST/POSTGRES_* 等分散字段
DATABASE_URL=postgresql://smartlearn_user:your-password@localhost:5432/smartlearn

# ────────────────────────────────────────────────────────────
# ⭐ 必填：Redis 缓存
# ────────────────────────────────────────────────────────────
# 格式: redis://:密码@主机:端口/0  （无密码则 redis://主机:端口/0）
REDIS_URL=redis://:your-password@localhost:6379/0

# ────────────────────────────────────────────────────────────
# ⭐ 必填：JWT 签名密钥
# ────────────────────────────────────────────────────────────
# 生成方式: openssl rand -hex 32  （长度 ≥ 32 的随机字符串）
# ⚠️ 以下仅为占位符！复制到 .env 后会因"弱密钥/占位值"被生产环境拒绝启动，
#    请务必替换为 openssl rand -hex 32 生成的强随机值。
JWT_SECRET=your-jwt-secret-please-generate-with-openssl-rand-hex-32

# ────────────────────────────────────────────────────────────
# ⭐ 必填：环境标识
# ────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false


# ============================================================
# 🔐 AI Engine 鉴权与安全（ai-engine 微服务）
# ============================================================
# ai-engine 默认开启全局鉴权。匿名调用 /chat、/moderation、/media/*、
# /prompts 写接口、/word-games 等将被拒绝（401/403）。
# 调用方需携带 X-Api-Key（=下方 AI_ENGINE_API_KEY）或服务间 JWT
# （复用上方 JWT_SECRET 签名，与 api 服务同一密钥）。
AI_ENGINE_AUTH_ENABLED=true

# 服务间 / 网关凭证。请生成强随机值，例如: openssl rand -hex 32
# ⚠️ 留空会导致 ai-engine 在鉴权开启时拒绝启动（fail-fast）。
AI_ENGINE_API_KEY=change-me-generate-with-openssl-rand-hex-32

# 复用上方 JWT_SECRET 作为 AI Engine 的 JWT 校验密钥（保持与 api 一致）。
# 下方 JWT_ALGORITHM 同理。
JWT_ALGORITHM=HS256

# SSRF 防护：允许 ai-engine 服务端出网抓取的域名白名单（逗号分隔）。
# 留空表示仅允许公网 http/https 非内网地址；如有可信音频源域名可在此追加。
AI_ENGINE_SSRF_ALLOWLIST=


# ============================================================
# 🤖 AI 服务 (4 家供应商，至少配置 1 个即可启用 AI 功能)
# ============================================================
# 所有供应商均兼容 OpenAI API 协议，按需填写你有的 Key。
# 推荐: GLM (免费) + DeepSeek (便宜) 组合即可覆盖绝大多数场景。

# ── 1) GLM (智谱 AI) — 默认聊天主供应商 ──────────────────
# 注册: https://open.bigmodel.cn/  (新用户送免费额度)
# 模型说明:
#   glm-4-flash      永久免费, 128K 上下文, 日常对话/讲解推荐
#   glm-4            标准版, 128K 上下文, 更强推理
#   glm-4-plus       高精度版, 128K 上下文, 复杂问题
#   glm-4v           多模态, 支持图像理解
# 用途: AI 对话、知识点讲解、题目解析
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4-flash

# ── 2) DeepSeek — 高难度推理 / 数学计算 ─────────────────
# 注册: https://platform.deepseek.com/  (充值 ¥10 即可用很久)
# 模型说明:
#   deepseek-chat     DeepSeek-V3, 64K 上下文, ¥1/百万token
#   deepseek-reasoner DeepSeek-R1, 推理增强, ¥4/百万token
# 用途: 难题求解、数学推导、代码生成
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── 3) SiliconFlow (硅基流动) — 嵌入/TTS/语音识别 ───────
# 注册: https://siliconflow.cn/  (新用户送 ¥14 额度)
# 模型说明:
#   BAAI/bge-m3       多语言嵌入模型, 向量检索用 (免费)
#   CosyVoice         语音合成 TTS
#   SenseVoice        语音识别 STT
# 用途: 知识库向量化、语音朗读、语音输入
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_TTS_MODEL=CosyVoice
SILICONFLOW_STT_MODEL=SenseVoice

# ── 4) CogView (智谱 AI) — 图像生成 ─────────────────────
# 注册: https://open.bigmodel.cn/  (与 GLM 共享额度)
# 模型说明:
#   cogview-3-flash   快速图像生成, 适合题目配图/学习卡片
# 用途: 生成题目插图、知识点思维导图
COGVIEW_API_KEY=
COGVIEW_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
COGVIEW_MODEL=cogview-3-flash


# ============================================================
# 📦 对象存储 (可选 — 用于头像/文件上传)
# ============================================================
# 支持 S3 兼容协议。推荐免费方案:
#
# 🥇 Cloudflare R2 (最推荐, 10GB 免费 + 无出站费)
#    注册: https://dash.cloudflare.com  → R2 → 创建存储桶
#    获取: R2 Account ID + Access Key + Secret (在 R2 → Manage R2 API Tokens)
#    填法:
#      OSS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#      OSS_ACCESS_KEY=<your-r2-access-key>
#      OSS_SECRET_KEY=<your-r2-secret-key>
#      OSS_BUCKET=<your-bucket-name>
#      OSS_REGION=auto
#
# 🥈 Backblaze B2 (10GB 免费, S3 兼容)
#    注册: https://www.backblaze.com/b2  → 创建 bucket → S3 Info
#    填法:
#      OSS_ENDPOINT=https://s3.<region>.backblazeb2.com
#      OSS_ACCESS_KEY=<keyID>
#      OSS_SECRET_KEY=<applicationKey>
#      OSS_BUCKET=<bucket-name>
#      OSS_REGION=<region>
#
# 🥉 阿里云 OSS (有免费额度, 国内速度最快)
#    OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
#    OSS_ACCESS_KEY=<your-access-key>
#    OSS_SECRET_KEY=<your-secret-key>
#    OSS_BUCKET=<your-bucket>
#    OSS_REGION=oss-cn-hangzhou
#
# 留空 = 不启用文件上传功能 (应用与管理后台正常运行)
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_REGION=


# ============================================================
# 💳 支付 (可选 — 留空不影响启动和管理员手动加权限)
# ============================================================
# 微信支付: https://pay.weixin.qq.com/
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
# 支付宝: https://open.alipay.com/
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=


# ============================================================
# 📱 短信 (可选 — 留空则改用邮箱/密码登录)
# ============================================================
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=SmartLearn


# ============================================================
# 📧 邮件 (可选 — 留空则不发送通知邮件)
# ============================================================
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=


# ============================================================
# 🌐 部署相关 (生产环境部署时填写)
# ============================================================
# CORS 允许的前端源 (逗号分隔, 生产环境改为实际域名)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# HTTPS 证书 (Let's Encrypt, 部署脚本用)
DOMAIN=
CERTBOT_EMAIL=

# 数据库自动备份 (db-backup 服务用, 可选)
BACKUP_CRON=0 2 * * *
BACKUP_RETAIN_DAYS=7


# ============================================================
# 📝 以下为 Docker Compose 内置数据库时才需要 (一般留空即可)
# ============================================================
# 仅当使用 compose 自带的 db 容器时, 用这些变量初始化数据库
# 如果你已填 DATABASE_URL 指向外部数据库, 以下可忽略
POSTGRES_USER=smartlearn_user
POSTGRES_PASSWORD=smartlearn_local_password
REDIS_PASSWORD=smartlearn_redis_password
POSTGRES_DB=smartlearn
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
