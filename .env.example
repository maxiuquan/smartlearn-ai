# ============================================================
# SmartLearn AI - 环境配置模板（含 Hugging Face Spaces 部署版）
# ============================================================
# 使用方法：
#   本地开发：  cp .env.example .env，按下方说明逐项填入
#   HF Spaces： 将这些变量填到 HF Space → Settings → Repository secrets
#
# 📌 最低启动只需填 3 项：
#     1. DATABASE_URL   ⭐ 数据库连接串
#     2. REDIS_URL      ⭐ Redis 连接串
#     3. JWT_SECRET     ⭐ JWT 签名密钥
#   再加至少 1 个 AI API Key，应用即可完整运行。
#   支付/短信/邮件/OSS 全部可选，留空不影响启动与管理后台。
# ============================================================


# ────────────────────────────────────────────────────────────
# ⭐ 必填项 1/3：数据库 (PostgreSQL)
# ────────────────────────────────────────────────────────────
# 【这是什么】PostgreSQL 是关系型数据库，存用户账号、课程、游戏成绩、订单等所有业务数据。
#
# 【怎么获取】
#   方式 A（本地开发）：用 Docker Compose 自带的 db 容器，填下方 POSTGRES_* 对应的值即可
#   方式 B（本地开发）：本地装 PostgreSQL，从 pgAdmin 或命令行 \conninfo 查到连接信息
#   方式 C（HF Spaces 部署，推荐 ⭐）：用 Aiven PostgreSQL 免费档
#
# 【方式 C：Aiven PostgreSQL 免费档申请步骤】
#   1. 注册 Aiven 账号：https://aiven.io/ （支持 GitHub/Google 登录）
#   2. 控制台 → "New service" → 选择 "PostgreSQL"
#   3. 选择 "Free-1-5" 免费计划（1 GB RAM / 1 vCPU / 5 GB 存储）
#   4. 云商选 Google Cloud，区域选 google-us-east1（免费档只有这个区域）
#   5. 创建后等 2-3 分钟，服务状态变为 "Running"
#   6. 在 "Overview" 页面找到 "Connection information"：
#      - Service URI 格式：postgresql://avnadmin:你的密码@host:port/defaultdb
#      - 这个 Service URI 就是 DATABASE_URL
#   7. 注意：免费档 IP 白名单默认允许所有 IP（0.0.0.0/0），
#      HF Space 每次重启 IP 会变，所以不要设固定 IP 白名单
#
# 【格式】postgresql://用户名:密码@主机:端口/数据库名
# 【示例】postgresql://avnadmin:pass@pg-host.aivencloud.com:12345/defaultdb
# 【注意】填此项后无需再填 DB_HOST/POSTGRES_* 等分散字段
DATABASE_URL=postgresql://smartlearn_user:your-password@localhost:5432/smartlearn


# ────────────────────────────────────────────────────────────
# ⭐ 必填项 2/3：Redis 缓存
# ────────────────────────────────────────────────────────────
# 【这是什么】Redis 是内存级键值数据库，本项目用它做：
#   - 系统配置缓存（管理后台改的配置存这，避免每次请求都读 PG）
#   - Celery 异步任务队列（发邮件/短信/文件处理的 broker）
#   - 限流计数（登录失败次数、API 防刷）
#   注：HF Spaces 部署时用 APScheduler 替代 Celery Beat，但 Redis 仍用于配置缓存
#
# 【怎么获取】
#   方式 A（本地开发）：用 Docker Compose 自带的 redis 容器，密码见下方 REDIS_PASSWORD
#   方式 B（本地开发）：本地装 Redis，默认无密码 redis://localhost:6379/0
#   方式 C（HF Spaces 部署，推荐 ⭐）：用 Upstash Redis 免费档
#
# 【方式 C：Upstash Redis 免费档申请步骤】
#   1. 注册 Upstash 账号：https://upstash.com/ （支持 GitHub/Google 登录）
#   2. 控制台 → "Redis" → "Create Database"
#   3. 填写名称（如 smartlearn-redis），区域选 US-East-1（与 Aiven PG 同区域，延迟低）
#   4. 创建后在 "Details" 页面找到 "Endpoint" 和 "Port"：
#      - Endpoint 格式：your-db-name.upstash.io
#      - Password：点击 "UPSTASH_REDIS_REST_TOKEN" 旁的复制按钮
#   5. 在 "REST API" 区域找到完整连接串：
#      格式：redis://default:你的密码@your-db.upstash.io:6379
#   6. 免费额度：每天 10,000 命令，个人项目足够用
#   7. 注意：Upstash 有闲置超时，/keepalive 端点会定期 ping 保活
#
# 【格式】
#   有密码：redis://:密码@主机:端口/0
#   无密码：redis://主机:端口/0
# 【示例】redis://default:pass@smartlearn-redis.upstash.io:6379/0
REDIS_URL=redis://:your-password@localhost:6379/0


# ────────────────────────────────────────────────────────────
# ⭐ 必填项 3/3：JWT 签名密钥
# ────────────────────────────────────────────────────────────
# 【这是什么】JWT 是用户登录后的加密通行证。用户登录成功后，api 用此密钥签发 token，
#           后续请求带 Authorization: Bearer <token>，api 用同一密钥验证。
#           ai-engine 也复用同一密钥识别用户身份。
# 【怎么生成】在终端执行：openssl rand -hex 32
#           会输出 64 位十六进制字符串，直接复制粘贴到这里
# 【为什么必填】没有它任何人都能伪造 token 冒充任何用户，必须 ≥32 字符强随机值
# 【注意】以下仅为占位符！复制到 .env 后会因"弱密钥/占位值"被生产环境拒绝启动，
#       请务必替换为 openssl rand -hex 32 生成的强随机值。
# 【示例】JWT_SECRET=a3f4b8c9d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8
JWT_SECRET=your-jwt-secret-please-generate-with-openssl-rand-hex-32


# ────────────────────────────────────────────────────────────
# ⭐ 必填：环境标识
# ────────────────────────────────────────────────────────────
# 【这是什么】告诉应用当前跑在什么环境，不同环境行为不同
# 【怎么填】
#   development  - 本地开发（调试日志多，报错详细）
#   production   - 生产环境（性能优先，日志精简，强制 HTTPS）
#   staging      - 预发布环境（模拟生产测试）
# 【建议】本地开发用 development，HF Spaces 部署也用 development（免费档无需强制 HTTPS）
ENVIRONMENT=development
# 【DEBUG 是什么】是否开启调试模式，开启后报错会显示完整堆栈（方便排查，但生产环境有安全风险）
# 【怎么填】本地开发 true，生产环境必须 false
DEBUG=false


# ============================================================
# 🔐 AI Engine 鉴权与安全（ai-engine 微服务）
# ============================================================
# 【背景】ai-engine 是独立微服务（端口 8001），提供 AI 对话、游戏出题、内容审核等能力。
#       HF Spaces 部署时，nginx 反代 /word-games/ 到 ai-engine 时注入 X-Api-Key。
#
# 两种调用方式：
#   1. 学生前端 → Authorization: Bearer <JWT>     （用户身份，用于游戏成绩入库到对应 user_id）
#   2. api/nginx → X-Api-Key: <AI_ENGINE_API_KEY>  （服务间凭证，用于代理转发）

# 【是否开启鉴权】true=开启（推荐，匿名调用直接 401）；false=关闭（仅本地调试用）
# 【建议】生产环境必须 true
AI_ENGINE_AUTH_ENABLED=true

# 【这是什么】ai-engine 的服务间凭证。nginx 反代 /word-games/ 时注入此密钥。
# 【怎么生成】openssl rand -hex 32
# 【注意】
#   - 留空会导致 ai-engine 在鉴权开启时拒绝启动（fail-fast）
#   - HF Spaces 部署时，entrypoint.sh 会自动将此值注入到 nginx 配置中
AI_ENGINE_API_KEY=change-me-generate-with-openssl-rand-hex-32

# 【这是什么】JWT 签名算法，与 api 服务保持一致
# 【怎么填】固定填 HS256（除非你有特殊需求）
JWT_ALGORITHM=HS256

# 【这是什么】SSRF 防护白名单。ai-engine 服务端出网抓取 URL 时（如 TTS 朗读音频源），
#           只允许访问此白名单里的域名，防止恶意请求内网
# 【怎么填】
#   留空 = 仅允许公网 http/https 非内网地址（默认安全）
#   填域名 = 逗号分隔，如：open.bigmodel.cn,siliconflow.cn
# 【建议】留空即可，除非你有特定的可信音频源/图片源需要放行
AI_ENGINE_SSRF_ALLOWLIST=

# 【这是什么】ai-engine 的数据库连接串。ai-engine 通过 asyncpg 连接共享 PG 实例，
#           用于游戏 session / 排行榜 / 对话历史持久化
# 【怎么填】
#   Docker 部署：由 compose 自动注入 DATABASE_URL（与上方相同），无需手动改
#   HF Spaces 部署：此变量需手动填入，与 DATABASE_URL 相同的值
#   本地开发：指向本地 PG 实例，与 DATABASE_URL 相同即可
# 【格式】postgresql://用户名:密码@主机:端口/数据库名
AI_ENGINE_DATABASE_URL=postgresql://smartlearn_user:your-password@localhost:5432/smartlearn


# ============================================================
# 🤖 AI 服务 (4 家供应商，至少配置 1 个即可启用 AI 功能)
# ============================================================
# 【背景】所有供应商均兼容 OpenAI API 协议，按需填写你有的 Key。
# 【推荐】GLM（免费）+ DeepSeek（便宜）组合即可覆盖绝大多数场景。
# 【注意】至少配 1 个 Key 才能用 AI 对话/讲解/出题等功能，全留空会进入离线模式（仅模拟响应）

# ── 1) GLM (智谱 AI) — 默认聊天主供应商 ──────────────────
# 【注册地址】https://open.bigmodel.cn/  （新用户送免费额度）
# 【怎么获取 API Key】注册后在控制台 → API Keys → 创建新 Key → 复制
# 【模型说明】
#   glm-4-flash      永久免费, 128K 上下文, 日常对话/讲解推荐
#   glm-4            标准版, 128K 上下文, 更强推理
#   glm-4-plus       高精度版, 128K 上下文, 复杂问题
#   glm-4v           多模态, 支持图像理解
# 【用途】AI 对话、知识点讲解、题目解析
# 【怎么填】把 GLM_API_KEY= 后面填上你复制的 Key，其他保持默认即可
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4-flash

# ── 2) DeepSeek — 高难度推理 / 数学计算 ─────────────────
# 【注册地址】https://platform.deepseek.com/  （充值 ¥10 即可用很久）
# 【怎么获取 API Key】注册后在控制台 → API keys → 创建 API key → 复制
# 【模型说明】
#   deepseek-chat     DeepSeek-V3, 64K 上下文, ¥1/百万token
#   deepseek-reasoner DeepSeek-R1, 推理增强, ¥4/百万token
# 【用途】难题求解、数学推导、代码生成
# 【怎么填】把 DEEPSEEK_API_KEY= 后面填上你复制的 Key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── 3) SiliconFlow (硅基流动) — 嵌入/TTS/语音识别 ───────
# 【注册地址】https://siliconflow.cn/  （新用户送 ¥14 额度）
# 【怎么获取 API Key】注册后在控制台 → API 密钥 → 新建密钥 → 复制
# 【模型说明】
#   BAAI/bge-m3       多语言嵌入模型, 向量检索用 (免费)
#   CosyVoice         语音合成 TTS
#   SenseVoice        语音识别 STT
# 【用途】知识库向量化、语音朗读、语音输入
# 【怎么填】把 SILICONFLOW_API_KEY= 后面填上你复制的 Key
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_TTS_MODEL=CosyVoice
SILICONFLOW_STT_MODEL=SenseVoice

# ── 4) CogView (智谱 AI) — 图像生成 ─────────────────────
# 【注册地址】https://open.bigmodel.cn/  （与 GLM 共享额度）
# 【怎么获取 API Key】同 GLM，复用同一个 API Key
# 【模型说明】
#   cogview-3-flash   快速图像生成, 适合题目配图/学习卡片
# 【用途】生成题目插图、知识点思维导图
# 【怎么填】COGVIEW_API_KEY 与 GLM_API_KEY 填同一个值即可
COGVIEW_API_KEY=
COGVIEW_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
COGVIEW_MODEL=cogview-3-flash


# ============================================================
# 🔔 Upstash QStash — 保活定时任务（HF Spaces 部署必配）
# ============================================================
# 【这是什么】QStash 是 Upstash 的 Serverless 消息队列 + Cron 调度服务
# 【为什么需要】HF Spaces 免费档 48h 无访问会休眠，Aiven/Upstash 免费档也有闲置超时
#             用 QStash Cron 定期 ping /keepalive 端点，同时保活 3 个服务：
#             - HF Space（防睡眠）
#             - Aiven PG（防闲置断开）
#             - Upstash Redis（防闲置断开）
#
# 【申请步骤】
#   1. 在 Upstash 控制台 → "QStash" → "Schedules" → "Create Schedule"
#   2. 填写：
#      - Destination URL: https://你的用户名-smartlearn.hf.space/keepalive
#      - Cron: */5 * * * *（每5分钟执行一次）
#   3. 免费额度：每天 500 次请求（每5分钟 = 每天 288 次，在免费额度内）
#   4. 注意：HF Space 首次唤醒需 30-60s，QStash 会自动重试
#
# 【此变量无需填写值】QStash 通过 HTTP 调用，不需要在环境变量中配置
# 仅作记录用，实际配置在 Upstash 控制台完成


# ============================================================
# 📦 对象存储 (可选 — 用于头像/文件上传)
# ============================================================
# 【这是什么】S3 兼容的对象存储，用于用户头像、作业图片、学习资料等文件上传
# 【是否必填】否，留空不影响应用启动和管理后台，只是不能上传文件
# 【推荐方案】Backblaze B2 — 10GB 免费, S3 兼容, 个人邮箱注册即可
#
# 【Backblaze B2 申请步骤】
#   1. 注册: https://www.backblaze.com/b2/ （邮箱即可,无需信用卡）
#   2. 创建 bucket: 左侧 "Buckets" → "Create a Bucket" → 选 "Public" 或 "Private"
#   3. 获取凭证: 左侧 "App Keys" → "Add a New Application Key"
#      - 选你的 bucket
#      - 复制 keyID (这是 OSS_ACCESS_KEY)
#      - 复制 applicationKey (这是 OSS_SECRET_KEY)
#   4. 获取 Endpoint: 左侧 "Buckets" → 点击你的 bucket
#      - 找到 "S3 Endpoint",格式如: s3.us-west-004.backblazeb2.com
#   5. 填法：
#       OSS_ENDPOINT=https://s3.us-west-004.backblazeb2.com
#       OSS_ACCESS_KEY=你的keyID
#       OSS_SECRET_KEY=你的applicationKey
#       OSS_BUCKET=你的bucket名称
#       OSS_REGION=(留空即可,region已包含在endpoint中)
#
# 【注意】留空 = 不启用文件上传功能 (应用与管理后台正常运行)
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_REGION=


# ============================================================
# 💳 支付 (可选 — 留空不影响启动和管理员手动加权限)
# ============================================================
# 【这是什么】在线支付功能，用于会员订阅、课程购买等
# 【是否必填】否，留空时管理员可在后台手动给用户加 VIP/权限
# 【怎么获取】需要企业资质，个人开发可先留空

# ── 微信支付 ──
# 【注册地址】https://pay.weixin.qq.com/
# 【需要什么】微信商户号 + API 密钥（在商户平台 → 账户中心 → API 安全设置）
# 【注意】需要企业资质，申请后会有 APP_ID（公众号/小程序）、MCH_ID（商户号）、API_KEY（密钥）
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# ── 支付宝 ──
# 【注册地址】https://open.alipay.com/
# 【需要什么】应用 APP_ID + 应用私钥 + 支付宝公钥
# 【注意】需要在蚂蚁开放平台创建应用，下载密钥工具生成密钥对
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=


# ============================================================
# 📱 短信 (可选 — 留空则改用邮箱/密码登录)
# ============================================================
# 【这是什么】短信验证码登录功能
# 【是否必填】否，留空时用户用邮箱+密码登录
# 【怎么获取】阿里云短信 / 腾讯云短信，需要企业资质
# 【填法】
#   SMS_ACCESS_KEY  - 阿里云 AccessKey
#   SMS_SECRET_KEY  - 阿里云 SecretKey
#   SMS_SIGN_NAME   - 短信签名（如 "SmartLearn"，需在短信平台审核通过）
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=SmartLearn


# ============================================================
# 📧 邮件 (可选 — 留空则不发送通知邮件)
# ============================================================
# 【这是什么】邮件通知功能，用于注册验证码、密码重置、系统通知
# 【是否必填】否，留空时不发邮件，用户用邮箱+密码直接登录
# 【怎么获取】推荐用 QQ 邮箱 / 163 邮箱 / Gmail，免费
# 【QQ 邮箱填法】
#   1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 SMTP 服务
#   2. 获取授权码（不是 QQ 密码，是 SMTP 授权码）
#   3. 填：SMTP_HOST=smtp.qq.com, SMTP_USER=你的QQ邮箱, SMTP_PASS=授权码
# 【163 邮箱填法】
#   1. 登录 163 邮箱 → 设置 → POP3/SMTP/IMAP → 开启 SMTP
#   2. 设置客户端授权密码
#   3. 填：SMTP_HOST=smtp.163.com, SMTP_USER=你的163邮箱, SMTP_PASS=授权码
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=


# ============================================================
# 👤 初始管理员账号 (通过 scripts/seed.py 初始化到数据库)
# ============================================================
# 【这是什么】系统第一个超级管理员账号，用于登录管理后台
# 【为什么不在 .env 直接配密码】密码经 bcrypt 哈希后存数据库，比明文存 .env 更安全
# 【怎么用】
#   1. 先执行 alembic upgrade head 创建表（已由 Dockerfile 自动执行）
#   2. 执行初始化脚本：cd services/api && python scripts/seed.py
#   3. 脚本会创建超级管理员账号（已存在则跳过，幂等可重复执行）
#   4. 用此账号登录管理后台
# 【HF Spaces 部署】entrypoint.sh 会自动执行 seed.py，无需手动操作
# 【自定义账号密码】在执行脚本前，覆盖以下环境变量：
#   export SEED_ADMIN_EMAIL=你的邮箱
#   export SEED_ADMIN_PASSWORD=你的强密码
#   python scripts/seed.py
# ⚠️ 默认密码仅用于本地演示，生产环境务必用 SEED_ADMIN_PASSWORD 覆盖！
# 创建后请尽快通过管理后台修改密码。
SEED_ADMIN_EMAIL=admin@smartlearn.io
SEED_ADMIN_PASSWORD=Admin@12345678
SEED_ADMIN_NICKNAME=系统管理员


# ============================================================
# 🌐 部署相关 (生产环境部署时填写)
# ============================================================
# 【这是什么】部署相关的杂项配置

# CORS 允许的前端源（逗号分隔）
# 【这是什么】哪些前端地址可以调用 api，防止跨域攻击
# 【怎么填】
#   本地开发：http://localhost:3000,http://localhost:3001,http://localhost:5173
#   HF Spaces 部署：改为你的 Space 域名，如 https://你的用户名-smartlearn.hf.space
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# HTTPS 证书 (Let's Encrypt, 部署脚本用)
# 【这是什么】生产环境用 Let's Encrypt 自动申请免费 HTTPS 证书
# 【怎么填】
#   DOMAIN        - 你的域名，如 learn.example.com
#   CERTBOT_EMAIL - 你的邮箱，用于接收证书过期提醒
# 【注意】留空则用 HTTP（仅本地开发用，生产环境必须配 HTTPS）
# 【HF Spaces 部署】HF 自动提供 *.hf.space 域名的 HTTPS 证书，此项留空即可
DOMAIN=
CERTBOT_EMAIL=

# 数据库自动备份 (db-backup 服务用, 可选)
# 【这是什么】自动定时备份 PostgreSQL 数据库
# 【怎么填】
#   BACKUP_CRON        - 备份时间，cron 格式。默认 "0 2 * * *" = 每天凌晨 2 点
#   BACKUP_RETAIN_DAYS - 备份保留天数，超过则自动删除。默认 7 天
# 【cron 格式说明】分 时 日 月 周
#   0 2 * * *    - 每天凌晨 2 点
#   0 */6 * * *  - 每 6 小时
#   0 2 * * 0    - 每周日凌晨 2 点
# 【HF Spaces 部署】APScheduler 已配置每天 03:00 自动备份，此项可忽略
BACKUP_CRON=0 2 * * *
BACKUP_RETAIN_DAYS=7


# ============================================================
# 📝 以下为 Docker Compose 内置数据库时才需要 (一般留空即可)
# ============================================================
# 【背景】仅当使用 docker-compose.yml 自带的 db / redis 容器时，用这些变量初始化
# 【什么时候需要改】
#   - 用 compose 部署：这些值会用于初始化内置的 PostgreSQL 和 Redis 容器
#   - 已填 DATABASE_URL 指向外部数据库：以下可忽略
#   - HF Spaces 部署（用 Aiven + Upstash）：以下全部忽略
# 【注意】
#   - POSTGRES_PASSWORD 和 REDIS_PASSWORD 必须与上方 DATABASE_URL / REDIS_URL 里的密码一致
#   - 生产环境请改成强密码（openssl rand -hex 16）

# PostgreSQL 容器初始化用户名
POSTGRES_USER=smartlearn_user
# PostgreSQL 容器初始化密码（生产环境必须改成强密码）
POSTGRES_PASSWORD=smartlearn_local_password
# Redis 容器密码（生产环境必须改成强密码）
REDIS_PASSWORD=smartlearn_redis_password
# PostgreSQL 容器初始化数据库名
POSTGRES_DB=smartlearn
# Nginx HTTP 端口（默认 80，如主机 80 被占用改为 8080 等）
NGINX_HTTP_PORT=80
# Nginx HTTPS 端口（默认 443，如主机 443 被占用改为 8443 等）
NGINX_HTTPS_PORT=443


# ============================================================
# 🚀 Hugging Face Spaces 部署检查清单
# ============================================================
# 【部署步骤】
#   1. 在 HF 创建 Space：https://huggingface.co/new-space
#      - SDK 选 Docker
#      - License 选 MIT
#      - Visibility 选 Public 或 Private
#
#   2. 在 Space Settings → Repository secrets 添加以下变量：
#      ⭐ 必填（4 个）：
#        DATABASE_URL          → Aiven PG 连接串（api + ai-engine 共享读取）
#        REDIS_URL             → Upstash Redis 连接串
#        JWT_SECRET            → openssl rand -hex 32 生成的密钥
#        AI_ENGINE_API_KEY     → openssl rand -hex 32 生成的密钥
#
#      ⭐ 必填（至少 1 个 AI Key）：
#        GLM_API_KEY           → 智谱 AI 的 API Key（推荐，有免费额度）
#
#      📌 可选（按需）：
#        DEEPSEEK_API_KEY      → DeepSeek API Key
#        SILICONFLOW_API_KEY   → 硅基流动 API Key
#        SEED_ADMIN_EMAIL      → 管理员邮箱（默认 admin@smartlearn.local）
#        SEED_ADMIN_PASSWORD   → 管理员密码（默认 Admin@12345678，务必修改！）
#        CORS_ORIGINS          → https://你的用户名-smartlearn.hf.space
#        ENVIRONMENT           → development（免费档无需 production）
#        AI_ENGINE_AUTH_ENABLED → true
#
#   3. 推送代码到 HF Space Git 仓库：
#      git remote add space https://huggingface.co/spaces/你的用户名/smartlearn
#      git push space main
#
#   4. 在 Upstash 控制台配置 QStash 定时任务：
#      - 控制台 → QStash → Schedules → Create Schedule
#      - Destination URL: https://你的用户名-smartlearn.hf.space/keepalive
#      - Cron: */5 * * * *（每5分钟）
#      - 这会同时保活 HF Space + Aiven PG + Upstash Redis
#
#   5. 等待 HF Space 构建完成（首次约 10-15 分钟）
#
#   6. 访问：
#      - 学生端：https://你的用户名-smartlearn.hf.space/
#      - 管理后台：https://你的用户名-smartlearn.hf.space/admin/
#      - API 文档：https://你的用户名-smartlearn.hf.space/api/docs
#      - 健康检查：https://你的用户名-smartlearn.hf.space/health
#      - 保活端点：https://你的用户名-smartlearn.hf.space/keepalive
#
# 【免费额度汇总】
#   HF Spaces 免费 CPU 档：2 vCPU / 16 GB RAM / 50 GB 磁盘（永久免费）
#   Aiven PG 免费档：1 GB RAM / 5 GB 存储（永久免费，us-east-1）
#   Upstash Redis 免费档：10,000 命令/天（永久免费）
#   Upstash QStash 免费档：500 次/天（每5分钟 ping = 288 次/天）
#   GLM glm-4-flash：永久免费（128K 上下文）
# ============================================================
