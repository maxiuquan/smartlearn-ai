# SmartLearn AI 环境变量配置示例
# 复制此文件为 .env 并修改相应配置
# 注意: 生产环境必须替换所有 your_* 占位符为强随机值!

# ==================== 数据库配置 ====================
# PostgreSQL配置
POSTGRES_USER=smartlearn_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=smartlearn
POSTGRES_SERVER=db
POSTGRES_PORT=5432

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==================== MinIO 配置 (Milvus 依赖) ====================
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ==================== AI服务配置 ====================
# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# 模型配置
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# ==================== 应用配置 ====================
# JWT配置 (生产环境必须使用 32+ 字节随机密钥)
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS配置 (生产环境必须替换为真实域名)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# ==================== 服务端口配置 ====================
API_PORT=8000
AI_ENGINE_PORT=8001
MOBILE_PORT=3001
ADMIN_PORT=3000

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== 其他配置 ====================
# 环境 (注意: 开发环境使用 development, 生产环境部署时显式注入 production)
ENVIRONMENT=development

# 调试模式
DEBUG=false

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# 邮件配置 (可选)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# OSS配置 (可选)
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
